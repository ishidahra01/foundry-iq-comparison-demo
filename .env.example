# Foundry Agent Service Configuration
FOUNDRY_AGENT_ENDPOINT=https://your-foundry-agent-endpoint.azure.com
FOUNDRY_AGENT_API_KEY=your-api-key-here

# Agent Names
CLASSIC_RAG_AGENT_NAME=classic-rag-agent
FOUNDRY_IQ_AGENT_NAME=foundry-iq-agent

# Optional: Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional: Enable Mock Mode for Testing
MOCK_MODE=false
