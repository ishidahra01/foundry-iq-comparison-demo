# Azure AI Projects 2.x Configuration
AZURE_AI_PROJECT_ENDPOINT=https://your-ai-services-account.services.ai.azure.com/api/projects/your-project-name

# Agent Names
CLASSIC_RAG_AGENT_NAME=classic-rag-agent
FOUNDRY_IQ_AGENT_NAME=foundry-iq-agent

# Optional: Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Optional: Foundry-hosted model deployment used for answer evaluation
EVALUATION_MODEL=

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional: Enable Debug Mode for Agent Client
AGENT_CLIENT_DEBUG=true
AGENT_CLIENT_DEBUG_RAW=false

